# Copier ce fichier en .env et remplir les valeurs

SECRET_KEY=changez-moi-generez-une-vraie-cle-sur-djecrety.ir
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (laisser vide pour SQLite en local)
DATABASE_URL=

# E-mail (Gmail)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=ESCEP Niger <noreply@escep.ne>

# OTP
OTP_VALIDITY_MINUTES=10

# Analyse IA — ZeroGPT (GRATUIT sur zerogpt.com)
ZEROGPT_API_KEY=

# Analyse IA — GPTZero (payant ~45$/mois sur gptzero.me)
GPTZERO_API_KEY=

# Seuil rejet IA (%)
AI_DETECTION_THRESHOLD=70

# Cloudinary (optionnel, pour les fichiers media en production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
